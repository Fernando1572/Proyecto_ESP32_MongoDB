# ========================
# PUERTO DEL SERVIDOR
# ========================
# Define el puerto en el que se ejecutará tu aplicación Node.js.
# Si no se especifica, el código usa 3000 por defecto.
PORT=3000

# ========================
# CADENA DE CONEXIÓN MONGODB
# ========================
# URI de conexión a MongoDB Atlas.
# Contiene:
# - Usuario: admin
# - Contraseña: ***** (reemplaza con tu contraseña real)
# - Cluster: ***** (reemplaza con el nombre de tu cluster)
#
# Esta URI es usada por MongoClient para conectarse a la base de datos.
#
# IMPORTANTE:
# - Nunca compartas esta URI públicamente (contiene credenciales)
# - Asegúrate de que tu IP esté autorizada en MongoDB Atlas
#
MONGO_URI=mongodb+srv://admin:R3vrXnRzUjqXBZi@tutorial.kqz4h7g.mongodb.net/
